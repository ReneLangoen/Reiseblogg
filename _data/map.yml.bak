locations:
  - id: bergen
    label: Bergen
    weeks: [1]
    country: Norway
    lat: 60.3943
    lng: 5.3259


  - id: bangkok
    label: Bangkok
    weeks: [2]
    country: Thailand
    lat: 13.7563
    lng: 100.5018


  - id: tokyo
    label: Tokyo
    weeks: [3, 5]
    country: Japan
    lat: 35.6769
    lng: 139.7639



  - id: osaka
    label: Osaka
    weeks: [4]
    country: Japan
    lat: 34.6938
    lng: 135.5015

  - id: kofu
    label: Kofu
    country: Japan
    ghost: true
    lat: 35.6652
    lng: 138.5710

routes:

  - from: bergen
    to: bangkok
    mode: "Fly"
    distance_km: 10215.0

  - from: bangkok
    to: tokyo
    mode: "Fly"
    distance_km: 4608.5




  - from: tokyo
    to: osaka
    mode: "Bil"
    distance_km: 492.9

  - from: tokyo
    to: osaka
    mode: "Bil"
    distance_km: 492.9

  - from: osaka
    to: kofu
    mode: "Fly"
    distance_km: 299.1

# Legg til nye punkter med disse feltene:
# - id: oslo
#   label: Oslo
#   lat: 59.9139
#   lng: 10.7522
#
# Rekkefølgeinformasjon:
# - Punktrekkefølgen i "locations" bestemmer uke-tallene på kartet.
# - Markørene får automatisk "Uke 1", "Uke 2" osv. basert på rekkefølgen her.
# - Hvis du ønsker en annen rekkefølge, flytt elementene i listen.
#
# Ruteforklaring:
# - "from" og "to" refererer til id-ene i "locations".
# - "mode" brukes til å bestemme fargen i legend og på ruten.
# - Eksempel: mode: "Fly", "Tog", "Bil", "Buss" eller "Båt".
#
# Legg til nye ruter med disse feltene:
# - from: tokyo
#   to: osaka
#   mode: "Tog"
