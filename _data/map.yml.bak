locations:
  - id: bergen
    label: Bergen
    country: Norway
    lat: 60.3943
    lng: 5.3259  


  - id: bangkok
    label: Bangkok
    country: Thailand
    lat: 13.7563
    lng: 100.5018
    
  - id: tokyo
    label: Tokyo
    country: Japan
    lat: 35.6762
    lng: 139.6503


  - id: sendai
    label: Sendai
    country: Japan
    lat: 38.2678
    lng: 140.8691




  - id: kofu
    label: Kofu
    country: Japan
    ghost: true
    lat: 35.6652
    lng: 138.5710

  - id: osaka
    label: Osaka
    country: Japan
    lat: 34.6938
    lng: 135.5015

routes:

  - from: bergen
    to: bangkok
    mode: "Fly"
    distance_km: 10215.0

  - from: bangkok
    to: tokyo
    mode: "Fly"
    distance_km: 4598.9


  - from: tokyo
    to: sendai
    mode: "Bil"
    distance_km: 369.5



  - from: sendai
    to: kofu
    mode: "Bil"

# Legg til nye punkter med disse feltene:
# - id: oslo
#   label: Oslo
#   lat: 59.9139
#   lng: 10.7522
#
# Rekkefølgeinformasjon:
# - Punktrekkefølgen i "locations" bestemmer uke-tallene på kartet.
# - Markørene får automatisk "Uke 1", "Uke 2" osv. basert på rekkefølgen her.
# - Hvis du ønsker en annen rekkefølge, flytt elementene i listen.
#
# Ruteforklaring:
# - "from" og "to" refererer til id-ene i "locations".
# - "mode" brukes til å bestemme fargen i legend og på ruten.
# - Eksempel: mode: "Fly", "Tog", "Bil", "Buss" eller "Båt".
#
# Legg til nye ruter med disse feltene:
# - from: tokyo
#   to: osaka
#   mode: "Tog"
